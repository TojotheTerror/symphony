{
  "name": "@tojotheterror/symphony",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript scaffold for a repository-safe Symphony v0 implementation.",
  "type": "module",
  "bin": {
    "symphony": "./dist/src/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
